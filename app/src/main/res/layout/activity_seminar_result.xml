<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:padding="24dp">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnSaveImage">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="413dp"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="24dp">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@android:drawable/checkbox_on_background"
                app:tint="#4CAF50" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Pendaftaran Berhasil"
                android:textColor="#4CAF50"
                android:textSize="22sp"
                android:textStyle="bold" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="20dp"
                android:background="#E0E0E0" />

            <TableLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TableRow android:paddingVertical="4dp">

                    <TextView
                        android:text="Nama: "
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/resNama"
                        android:text="-" />
                </TableRow>

                <TableRow android:paddingVertical="4dp">

                    <TextView
                        android:text="Email: "
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/resEmail"
                        android:text="-" />
                </TableRow>

                <TableRow android:paddingVertical="4dp">

                    <TextView
                        android:text="No HP: "
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/resHP"
                        android:text="-" />
                </TableRow>

                <TableRow android:paddingVertical="4dp">

                    <TextView
                        android:layout_height="wrap_content"
                        android:text="jenis kelamin: "
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/resGender"
                        android:text="-" />
                </TableRow>

                <TableRow android:paddingVertical="4dp">

                    <TextView
                        android:text="Seminar: "
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/resSeminar"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:text="-" />
                </TableRow>

            </TableLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSaveImage"
        android:layout_width="297dp"
        android:layout_height="37dp"
        android:layout_marginBottom="20dp"
        android:backgroundTint="#A65CC34A"
        android:text="SAVE PENDAFTARAN"
        app:cornerRadius="12dp"
        app:layout_constraintBottom_toTopOf="@id/btnBack"
        tools:layout_editor_absoluteX="36dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBack"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="KEMBALI KE HALAMAN UTAMA"
        app:cornerRadius="12dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
