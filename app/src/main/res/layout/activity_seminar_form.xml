<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp">

        <!-- Elegant Header Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Seminar Registration"
            android:textColor="@color/edu_primary"
            android:textSize="28sp"
            android:fontFamily="serif"
            android:letterSpacing="0.02"
            android:textStyle="bold" />

        <View
            android:layout_width="80dp"
            android:layout_height="3dp"
            android:layout_marginTop="20dp"
            android:background="@color/white" />

        <!-- Form Section -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilNama"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:hint="Masukan Nama"
            app:boxStrokeColor="@color/edu_primary"
            app:hintTextColor="@color/edu_primary"
            app:startIconDrawable="@android:drawable/ic_menu_myplaces"
            app:startIconTint="@color/edu_primary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etNama"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif"
                android:textColor="@color/text_heading" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilEmail"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:hint="Masukan Email"
            app:boxStrokeColor="#03A9F4"
            app:hintTextColor="@color/edu_primary"
            app:startIconDrawable="@android:drawable/ic_dialog_email"
            app:startIconTint="@color/edu_primary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif"
                android:inputType="textEmailAddress"
                android:textColor="@color/text_heading" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilHP"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:hint="Masukan No WhatsApp"
            app:boxStrokeColor="@color/edu_primary"
            app:hintTextColor="@color/edu_primary"
            app:startIconDrawable="@android:drawable/stat_sys_phone_call"
            app:startIconTint="@color/edu_primary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etHP"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif"
                android:inputType="phone"
                android:textColor="@color/text_heading" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Pilih Jenis Kelamin"
            android:textColor="@color/edu_primary"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/rgGender"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/rbLaki"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Laki-Laki"
                android:buttonTint="@color/edu_primary"
                android:fontFamily="sans-serif"
                android:textColor="@color/text_body" />

            <RadioButton
                android:id="@+id/rbPerempuan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="32dp"
                android:text="Perempuan"
                android:buttonTint="@color/edu_primary"
                android:fontFamily="sans-serif"
                android:textColor="@color/text_body" />
        </RadioGroup>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Pilih Seminar"
            android:textColor="@color/edu_primary"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:strokeColor="@color/edu_secondary"
            app:strokeWidth="1.5dp">

            <Spinner
                android:id="@+id/spinnerSeminar"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="@android:color/transparent" />
        </com.google.android.material.card.MaterialCardView>

        <CheckBox
            android:id="@+id/cbAgree"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Saya menyetujui data yang diinput benar."
            android:buttonTint="#3F51B5"
            android:textColor="@color/black"
            android:fontFamily="sans-serif-light"
            android:textSize="13sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubmit"
            android:layout_width="match_parent"
            android:layout_height="68dp"
            android:layout_marginTop="40dp"
            android:text="COMPLETE REGISTRATION"
            android:textSize="15sp"
            android:letterSpacing="0.08"
            android:fontFamily="sans-serif-black"
            android:backgroundTint="@color/edu_primary"
            android:textColor="@color/white"
            app:cornerRadius="14dp"
            app:elevation="6dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
